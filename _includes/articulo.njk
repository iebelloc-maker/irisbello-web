<script>
  (function() {
    document.querySelectorAll('.nav-has-dropdown').forEach(function(item) {
      var t;
      item.addEventListener('mouseenter', function() { clearTimeout(t); item.classList.add('open'); });
      item.addEventListener('mouseleave', function() { t = setTimeout(function() { item.classList.remove('open'); }, 220); });
    });
  })();

  (function() {
    var btn = document.querySelector('.nav-hamburger');
    var menu = document.querySelector('.nav-mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        btn.classList.toggle('open');
        menu.classList.toggle('open');
        document.body.style.overflow = menu.classList.contains('open') ? 'hidden' : '';
      });
    }
    document.querySelectorAll('.nav-mobile-servicios > a').forEach(function(trigger) {
      var sub = trigger.nextElementSibling;
      if (sub && sub.classList.contains('nav-mobile-sub')) {
        trigger.addEventListener('click', function(e) {
          e.preventDefault();
          sub.classList.toggle('open');
          var arrow = trigger.querySelector('.arrow');
          if (arrow) arrow.textContent = sub.classList.contains('open') ? '▴' : '▾';
        });
      }
    });
    var closeBtn = menu ? menu.querySelector('.nav-mobile-close') : null;
    if (closeBtn) { closeBtn.addEventListener('click', function() { btn.classList.remove('open'); menu.classList.remove('open'); document.body.style.overflow = ''; }); }
  })();

  (function() {
    var REPO = 'iebelloc-maker/irisbello-web';

    function parseFM(text) {
      var m = text.match(/^---\n([\s\S]*?)\n---/);
      if (!m) return {};
      var fm = {};
      m[1].split('\n').forEach(function(line) {
        var idx = line.indexOf(':');
        if (idx > -1) {
          var k = line.slice(0, idx).trim();
          var v = line.slice(idx + 1).trim().replace(/^["']|["']$/g, '');
          fm[k] = v;
        }
      });
      return fm;
    }

    fetch('https://api.github.com/repos/' + REPO + '/contents/_noticias?ref=main')
      .then(function(r) { return r.ok ? r.json() : []; })
      .then(function(files) {
        if (!Array.isArray(files) || files.length === 0) {
          document.getElementById('sidebar-tablon').style.display = 'none';
          return;
        }
        var md = files.filter(function(f) { return f.name.endsWith('.md'); });
        if (md.length === 0) { document.getElementById('sidebar-tablon').style.display = 'none'; return; }
        return fetch(md[md.length - 1].download_url).then(function(r) { return r.text(); }).then(function(text) {
          var fm = parseFM(text);
          var container = document.getElementById('aviso-container');
          var fechaAviso = '';
          if (fm.date) {
            var d = new Date(fm.date);
            fechaAviso = d.toLocaleDateString('es-DO', { day: 'numeric', month: 'long', year: 'numeric' });
          }
          container.innerHTML = '<div class="aviso">' +
            '<span class="aviso-tipo">' + (fm.tipo || 'Aviso') + '</span>' +
            '<p class="aviso-titulo">' + (fm.title || '') + '</p>' +
            (fm.texto ? '<p class="aviso-texto">' + fm.texto + '</p>' : '') +
            (fm.enlace ? '<a href="' + fm.enlace + '" target="_blank" rel="noopener" style="display:inline-block;margin-top:0.6rem;font-family:Jost,sans-serif;font-size:0.75rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--rosa-antiguo);text-decoration:none;border-bottom:1px solid var(--rosa-antiguo);padding-bottom:2px;">Reservar lugar →</a>' : '') +
            '<p class="aviso-fecha">' + fechaAviso + '</p>' +
            '</div>';
        });
      })
      .catch(function() { document.getElementById('sidebar-tablon').style.display = 'none'; });

    fetch('https://api.github.com/repos/' + REPO + '/contents/_posts?ref=main')
      .then(function(r) { return r.ok ? r.json() : []; })
      .then(function(files) {
        if (!Array.isArray(files)) return;
        var md = files.filter(function(f) { return f.name.endsWith('.md'); }).slice(-3).reverse();
        if (md.length === 0) { document.getElementById('sidebar-ultimos').style.display = 'none'; return; }
        return Promise.all(md.map(function(f) {
          return fetch(f.download_url).then(function(r) { return r.text(); }).then(function(text) {
            var fm = parseFM(text);
            fm.slug = f.name.replace(/\.md$/, '');
            return fm;
          });
        })).then(function(posts) {
          var container = document.getElementById('ultimos-container');
          container.innerHTML = posts.map(function(p) {
            var img = p.imagen
              ? '<img src="' + p.imagen + '" alt="' + p.title + '" class="ultimo-img">'
              : '<div class="ultimo-img-placeholder"></div>';
            return '<a href="/blog/' + p.slug + '/" style="text-decoration:none;display:flex;gap:0.75rem;margin-bottom:1rem;align-items:flex-start;padding-bottom:1rem;border-bottom:1px solid rgba(22,36,53,0.06);">' +
              img +
              '<div><p class="ultimo-titulo">' + p.title + '</p><p class="ultimo-meta">' + (p.tema || '') + '</p></div></a>';
          }).join('');
        });
      })
      .catch(function() { document.getElementById('sidebar-ultimos').style.display = 'none'; });
  })();
</script>

