  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ extracto }}",
    "datePublished": "{{ date }}",
    "url": "https://irisbello.com/blog/{{ page.fileSlug }}/",
    "author": {
      "@type": "Person",
      "name": "Dra. Iris Bello Castillo",
      "@id": "https://irisbello.com/#persona"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Dra. Iris Bello Castillo",
      "@id": "https://irisbello.com/#negocio"
    }
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --azul-tinta: #162435; --rosa-antiguo: #B5707A; --ambar-dorado: #C4963A;
      --blanco: #FFFFFF; --medianoche: #0B1520; --fondo-suave: #F7F4F0;
      --texto-oscuro: #1a2530; --texto-medio: #4a5568; --texto-suave: #4e5e6e;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Jost', sans-serif; background: var(--blanco); color: var(--texto-oscuro); font-weight: 300; line-height: 1.7; font-size: 17px; }
    h1, h2, h3 { font-family: 'DM Serif Display', serif; font-weight: 400; }
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0.75rem 4rem; display: flex; justify-content: space-between; align-items: center; background: var(--blanco); border-bottom: 1px solid rgba(196,150,58,0.2); }
    .nav-logo { font-family: 'DM Serif Display', serif; font-size: 0.9rem; color: var(--azul-tinta); text-decoration: none; }
    .nav-logo span { color: var(--rosa-antiguo); }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--azul-tinta); text-decoration: none; }
    .nav-cta a { font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; background: var(--rosa-antiguo); color: var(--blanco); padding: 0.55rem 1.2rem; text-decoration: none; }
    .articulo-hero { background: var(--azul-tinta); padding: 7rem 10% 4rem; }
    .articulo-tema { font-family: 'Jost', sans-serif; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--rosa-antiguo); display: block; margin-bottom: 1rem; }
    .articulo-titulo { font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--blanco); line-height: 1.15; margin-bottom: 1.5rem; }
    .articulo-meta { font-size: 0.78rem; color: rgba(255,255,255,0.5); font-family: 'Jost', sans-serif; }
    .articulo-imagen { width: 100%; max-height: 480px; object-fit: cover; display: block; }
    .articulo-body { max-width: 720px; margin: 0 auto; padding: 4rem 2rem 6rem; }
    .articulo-body p { margin-bottom: 1.5rem; font-size: 1.05rem; line-height: 1.85; color: var(--texto-medio); }
    .articulo-body h2 { font-size: 1.5rem; margin: 2.5rem 0 1rem; color: var(--azul-tinta); }
    .articulo-body h3 { font-size: 1.2rem; margin: 2rem 0 0.8rem; color: var(--azul-tinta); }
    .articulo-body ul, .articulo-body ol { padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .articulo-body li { margin-bottom: 0.5rem; color: var(--texto-medio); }
    .articulo-volver { display: inline-block; margin-bottom: 3rem; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rosa-antiguo); text-decoration: none; border-bottom: 1px solid var(--rosa-antiguo); padding-bottom: 2px; }
    .articulo-cta { background: var(--azul-tinta); padding: 5rem 10%; text-align: center; }
    .articulo-cta h2 { color: var(--blanco); font-size: 1.8rem; margin-bottom: 1rem; }
    .articulo-cta p { color: rgba(255,255,255,0.6); margin-bottom: 2rem; font-size: 0.95rem; }
    .btn-cta { display: inline-block; background: var(--rosa-antiguo); color: var(--blanco); padding: 0.9rem 2.5rem; text-decoration: none; font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase; }
    .wa-fab { position: fixed; bottom: 1.5rem; right: 1.5rem; width: 52px; height: 52px; background: #B5707A; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 999; text-decoration: none; }
    footer { background: var(--medianoche); color: rgba(255,255,255,0.5); padding: 3rem 10%; text-align: center; font-size: 0.8rem; }
    footer a { color: var(--rosa-antiguo); text-decoration: none; }
  </style>
</head>
<body>

<nav>
  <a href="/index.html" class="nav-logo">Dra. <span>Iris Bello</span></a>
  <ul class="nav-links">
    <li><a href="/terapia.html">Terapia</a></li>
    <li><a href="/conoceme.html">Conóceme</a></li>
    <li><a href="/blog.html">Blog</a></li>
    <li><a href="/contacto.html">Contacto</a></li>
  </ul>
  <div class="nav-cta"><a href="https://wa.me/18098481234">Agendar</a></div>
</nav>

<main>
  <div class="articulo-hero">
    <span class="articulo-tema">{{ tema }}</span>
    <h1 class="articulo-titulo">{{ title }}</h1>
    <span class="articulo-meta">{{ date | date: "%d de %B, %Y" }} · Dra. Iris Bello Castillo</span>
  </div>

  {% if imagen %}
  <img src="{{ imagen }}" alt="{{ title }}" class="articulo-imagen">
  {% endif %}

  <div class="articulo-body">
    <a href="/blog.html" class="articulo-volver">← Volver al blog</a>
    {{ content }}
  </div>

  <div class="articulo-cta">
    <h2>¿Esto resuena contigo?</h2>
    <p>Una conversación de 30 minutos puede darte más claridad que meses dando vueltas sola.</p>
    <a href="https://wa.me/18098481234?text=Hola%2C%20le%C3%AD%20un%20art%C3%ADculo%20en%20el%20blog%20y%20quisiera%20hablar." class="btn-cta">Hablemos por WhatsApp</a>
  </div>
</main>

