  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --azul-tinta: #162435; --rosa-antiguo: #B5707A; --ambar-dorado: #C4963A;
      --blanco: #FFFFFF; --medianoche: #0B1520;
      --texto-oscuro: #1a2530; --texto-medio: #4a5568; --texto-suave: #4e5e6e;
      --gris-calido: #f4f1ee;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Jost', sans-serif; background: var(--blanco); color: var(--texto-oscuro); font-weight: 300; line-height: 1.7; font-size: 17px; overflow-x: hidden; }
    h1, h2, h3, h4 { font-family: 'DM Serif Display', serif; font-weight: 400; line-height: 1.2; }

    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0.75rem 4rem; display: flex; justify-content: space-between; align-items: center; background: var(--blanco); border-bottom: 1px solid rgba(196,150,58,0.2); }
    .nav-logo { font-family: 'DM Serif Display', serif; font-size: 0.9rem; letter-spacing: 0.02em; color: var(--azul-tinta); text-decoration: none; line-height: 1.3; }
    .nav-logo span { display: block; font-family: 'Jost', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rosa-antiguo); margin-top: 2px; }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links > li > a { color: var(--texto-medio); text-decoration: none; font-family: 'Jost', sans-serif; font-size: 0.8rem; font-weight: 400; letter-spacing: 0.12em; text-transform: uppercase; transition: color 0.3s; }
    .nav-links > li > a:hover { color: var(--ambar-dorado); }
    .nav-has-dropdown { position: relative; }
    .nav-dropdown { visibility: hidden; opacity: 0; pointer-events: none; position: absolute; top: 100%; left: -1.5rem; padding-top: 0.8rem; z-index: 200; transition: opacity 0.18s ease, visibility 0.18s ease; }
    .nav-has-dropdown.open .nav-dropdown { visibility: visible; opacity: 1; pointer-events: auto; }
    .nav-dropdown-inner { list-style: none; background: var(--blanco); border: 1px solid rgba(22,36,53,0.08); border-radius: 2px; padding: 0.5rem 0; min-width: 200px; box-shadow: 0 8px 32px rgba(22,36,53,0.1); }
    .nav-dropdown-inner li a { display: block; padding: 0.65rem 1.25rem; font-family: 'Jost', sans-serif; font-size: 0.78rem; color: var(--texto-medio); text-decoration: none; transition: color 0.2s, background 0.2s; }
    .nav-dropdown-inner li a:hover { color: var(--azul-tinta); background: var(--gris-calido); }
    .nav-cta { font-family: 'Jost', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rosa-antiguo); text-decoration: none; border: 1px solid var(--rosa-antiguo); padding: 0.55rem 1.2rem; border-radius: 2px; transition: background 0.2s, color 0.2s; }
    .nav-cta:hover { background: var(--rosa-antiguo); color: var(--blanco); }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
    .nav-hamburger span { display: block; width: 22px; height: 1.5px; background: var(--azul-tinta); transition: transform 0.3s, opacity 0.3s; }
    .nav-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .nav-hamburger.open span:nth-child(2) { opacity: 0; }
    .nav-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
    .nav-mobile-close { position: absolute; top: 1.2rem; right: 1.2rem; background: none; border: none; cursor: pointer; padding: 0.5rem; display: flex; align-items: center; justify-content: center; z-index: 10; }
    .nav-mobile-close svg { width: 24px; height: 24px; stroke: var(--azul-tinta); stroke-width: 2; fill: none; }
    .nav-mobile-menu { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: var(--blanco); z-index: 150; flex-direction: column; padding: 6rem 2rem 3rem; overflow-y: auto; }
    .nav-mobile-menu.open { display: flex; }
    .nav-mobile-menu ul { list-style: none; display: flex; flex-direction: column; gap: 0; flex: 1; }
    .nav-mobile-menu ul li { border-bottom: 1px solid rgba(22,36,53,0.07); }
    .nav-mobile-menu ul li:first-child { border-top: 1px solid rgba(22,36,53,0.07); }
    .nav-mobile-menu ul li a { display: block; padding: 1.2rem 0; font-family: 'Jost', sans-serif; font-size: 1rem; color: var(--texto-oscuro); text-decoration: none; transition: color 0.2s; }
    .nav-mobile-menu ul li a:hover { color: var(--rosa-antiguo); }
    .nav-mobile-servicios > a { display: flex; justify-content: space-between; align-items: center; }
    .nav-mobile-sub { display: none; flex-direction: column; background: rgba(22,36,53,0.03); }
    .nav-mobile-sub.open { display: flex; }
    .nav-mobile-sub a { padding: 0.9rem 1.2rem !important; font-size: 0.88rem !important; color: var(--texto-medio) !important; border-bottom: 1px solid rgba(22,36,53,0.05) !important; }
    .nav-mobile-cta { margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(22,36,53,0.07); }
    .nav-mobile-cta a { display: block; background: var(--rosa-antiguo); color: #fff; text-align: center; padding: 1rem; font-family: 'Jost', sans-serif; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; }

    .articulo-hero { background: var(--azul-tinta); padding: 7rem 10% 3.5rem; }
    .articulo-tema { font-family: 'Jost', sans-serif; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--rosa-antiguo); display: block; margin-bottom: 0.8rem; }
    .articulo-titulo { font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--blanco); line-height: 1.15; margin-bottom: 0.8rem; }
    .articulo-extracto { font-size: 1rem; color: rgba(255,255,255,0.55); line-height: 1.7; margin-bottom: 1rem; font-style: italic; max-width: 640px; }
    .articulo-meta { font-size: 0.78rem; color: rgba(255,255,255,0.35); font-family: 'Jost', sans-serif; }

    .articulo-layout { display: grid; grid-template-columns: 1fr 300px; gap: 0; max-width: 100%; }

    .articulo-main { padding: 3rem 4rem; border-right: 1px solid rgba(22,36,53,0.08); }
    .articulo-img { width: 100%; max-height: 420px; object-fit: cover; display: block; margin-bottom: 2rem; }
    .articulo-volver { display: inline-block; margin-bottom: 2rem; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rosa-antiguo); text-decoration: none; border-bottom: 1px solid var(--rosa-antiguo); padding-bottom: 2px; font-family: 'Jost', sans-serif; }
    .articulo-body p { margin-bottom: 1.5rem; font-size: 1.05rem; line-height: 1.85; color: var(--texto-medio); }
    .articulo-body h2 { font-size: 1.5rem; margin: 2.5rem 0 1rem; color: var(--azul-tinta); }
    .articulo-body h3 { font-size: 1.2rem; margin: 2rem 0 0.8rem; color: var(--azul-tinta); }
    .articulo-body ul, .articulo-body ol { padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .articulo-body li { margin-bottom: 0.5rem; color: var(--texto-medio); }
    .articulo-body blockquote { border-left: 2px solid var(--rosa-antiguo); padding: 0.8rem 1.5rem; margin: 2rem 0; }
    .articulo-body blockquote p { font-style: italic; color: var(--azul-tinta); }
    .articulo-cta { border: 1px solid rgba(22,36,53,0.12); padding: 1.5rem 2rem; margin-top: 3rem; display: flex; justify-content: space-between; align-items: center; gap: 2rem; }
    .articulo-cta p { font-family: 'Jost', sans-serif; font-size: 0.9rem; color: var(--azul-tinta); font-weight: 400; }
    .articulo-cta-btn { display: inline-block; background: var(--azul-tinta); color: var(--blanco); font-family: 'Jost', sans-serif; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.7rem 1.5rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; transition: background 0.2s; }
    .articulo-cta-btn:hover { background: var(--rosa-antiguo); }

    .articulo-sidebar { padding: 3rem 2rem; }
    .sb-section { margin-bottom: 2.5rem; }
    .sb-label { font-family: 'Jost', sans-serif; font-size: 0.68rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ambar-dorado); border-bottom: 1px solid rgba(196,150,58,0.2); padding-bottom: 0.5rem; margin-bottom: 1rem; display: block; }
    .aviso { border: 1px solid rgba(22,36,53,0.1); padding: 1rem 1.1rem; }
    .aviso-tipo { font-family: 'Jost', sans-serif; font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--blanco); background: var(--ambar-dorado); padding: 0.18rem 0.5rem; display: inline-block; margin-bottom: 0.5rem; }
    .aviso-titulo { font-family: 'DM Serif Display', serif; font-size: 0.95rem; color: var(--azul-tinta); line-height: 1.3; margin-bottom: 0.4rem; }
    .aviso-texto { font-family: 'Jost', sans-serif; font-size: 0.78rem; color: var(--texto-medio); line-height: 1.5; margin-bottom: 0.5rem; }
    .aviso-fecha { font-family: 'Jost', sans-serif; font-size: 0.65rem; color: #aaa; }
    .ultimo-post { display: flex; gap: 0.75rem; margin-bottom: 1rem; align-items: flex-start; padding-bottom: 1rem; border-bottom: 1px solid rgba(22,36,53,0.06); }
    .ultimo-post:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .ultimo-img { width: 52px; height: 52px; flex-shrink: 0; object-fit: cover; }
    .ultimo-img-placeholder { width: 52px; height: 52px; flex-shrink: 0; background: rgba(22,36,53,0.06); }
    .ultimo-titulo { font-family: 'DM Serif Display', serif; font-size: 0.85rem; line-height: 1.3; color: var(--azul-tinta); margin-bottom: 0.2rem; }
    .ultimo-meta { font-family: 'Jost', sans-serif; font-size: 0.65rem; color: var(--rosa-antiguo); }
    .cats { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .cat-item { font-family: 'Jost', sans-serif; font-size: 0.65rem; color: var(--texto-medio); border: 1px solid rgba(22,36,53,0.12); padding: 0.25rem 0.6rem; text-decoration: none; transition: all 0.2s; }
    .cat-item:hover { background: var(--azul-tinta); color: var(--blanco); border-color: var(--azul-tinta); }

    .wa-fab { position: fixed; bottom: 2rem; right: 2rem; z-index: 9999; width: 56px; height: 56px; border-radius: 50%; background: #25D366; display: flex; align-items: center; justify-content: center; text-decoration: none; box-shadow: 0 4px 20px rgba(37,211,102,0.45); transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .wa-fab:hover { transform: translateY(-3px) scale(1.05); box-shadow: 0 8px 28px rgba(37,211,102,0.55); }

    footer { background: var(--medianoche); color: rgba(201,205,212,0.75); padding: 5rem 4rem 3rem; }
    .footer-grid { max-width: 1100px; margin: 0 auto 3rem; display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 3rem; }
    .footer-brand .logo-name { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: var(--blanco); margin-bottom: 4px; }
    .footer-brand .logo-title { font-family: 'Jost', sans-serif; font-size: 0.7rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--rosa-antiguo); display: block; margin-bottom: 1rem; }
    .footer-brand p { font-size: 0.82rem; line-height: 1.7; color: rgba(201,205,212,0.5); }
    .footer-col h4 { font-family: 'Jost', sans-serif; font-size: 0.7rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ambar-dorado); margin-bottom: 1rem; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
    .footer-col ul li a { font-family: 'Jost', sans-serif; font-size: 0.82rem; color: rgba(201,205,212,0.55); text-decoration: none; transition: color 0.2s; }
    .footer-col ul li a:hover { color: var(--blanco); }
    .footer-location { font-size: 0.75rem; color: rgba(201,205,212,0.3); margin-top: 1.5rem; }
    .footer-bottom { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; font-family: 'Jost', sans-serif; font-size: 0.75rem; color: rgba(201,205,212,0.3); letter-spacing: 0.08em; }

    @media (max-width: 1024px) {
      nav { padding: 0.75rem 2rem; }
      .articulo-layout { grid-template-columns: 1fr; }
      .articulo-main { padding: 2.5rem 2rem; border-right: none; border-bottom: 1px solid rgba(22,36,53,0.08); }
      .articulo-sidebar { padding: 2rem; }
      .footer-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    }
    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }
      .articulo-hero { padding: 6rem 1.5rem 2.5rem; }
      .articulo-main { padding: 2rem 1.5rem; }
      .articulo-sidebar { padding: 1.5rem; }
      .articulo-cta { flex-direction: column; align-items: flex-start; gap: 1rem; }
      footer { padding: 3rem 1.5rem 2rem; }
      .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    }
  </style>
</head>
