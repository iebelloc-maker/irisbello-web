  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <title>{{ title }} · Dra. Iris Bello Castillo · Psicóloga Clínica</title>
  <meta name="description" content="{{ extracto }}">
  <link rel="canonical" href="https://irisbello.com/blog/{{ page.fileSlug }}/">
  <meta property="og:title" content="{{ title }} · Dra. Iris Bello Castillo">
  <meta property="og:description" content="{{ extracto }}">
  <meta property="og:image" content="{% if imagen %}https://irisbello.com{{ imagen }}{% else %}https://irisbello.com/images/iris_bello_psicologa.jpg{% endif %}">
  <meta property="og:url" content="https://irisbello.com/blog/{{ page.fileSlug }}/">
